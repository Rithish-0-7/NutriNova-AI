{
  "name": "nutrinova-ai",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @nutrinova/web run dev",
    "dev:api": "npm --workspace @nutrinova/api run dev",
    "dev:ai": "python -m uvicorn app.main:app --app-dir apps/ai --reload --port 8001",
    "dev": "concurrently \"npm run dev:web\" \"npm run dev:api\" \"npm run dev:ai\"",
    "build": "npm --workspace @nutrinova/web run build",
    "start": "npm --workspace @nutrinova/web run start"
  },
  "devDependencies": {
    "concurrently": "^9.0.1"
  }
}
